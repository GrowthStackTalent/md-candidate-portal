# ── Flask ──────────────────────────────────────────────
# Generate a strong random key: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-long-random-string

# ── Admin portal ────────────────────────────────────────
ADMIN_PASSWORD=change-this-password

# ── Email notifications ─────────────────────────────────
# Leave SMTP_HOST blank to disable email notifications entirely.
#
# Gmail example (use an App Password, not your account password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=your-app-password
#   RECRUITER_EMAIL=recruiter@growthstacktalent.com
#
# Office 365 / Outlook example:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=you@yourdomain.com
#   SMTP_PASSWORD=your-password
#   RECRUITER_EMAIL=recruiter@growthstacktalent.com

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
RECRUITER_EMAIL=
